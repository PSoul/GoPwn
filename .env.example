# ============================================================
# 授权外网安全评估平台 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 数据库 (PostgreSQL + Prisma) ----------
DATABASE_URL="postgresql://pentest:pentest@localhost:5432/pentest?schema=public"

# ---------- 会话与认证 ----------
# 用于签名 session cookie 的密钥，建议 32+ 位随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROTOTYPE_SESSION_SECRET="change-me-to-a-random-secret"

# ---------- 初始管理员 (首次启动自动创建) ----------
ADMIN_EMAIL="admin@company.local"
ADMIN_PASSWORD="Admin@2026"
ADMIN_DISPLAY_NAME="系统管理员"

# ---------- LLM 配置 ----------
LLM_API_KEY=""
LLM_BASE_URL="https://api.siliconflow.cn/"
LLM_ORCHESTRATOR_MODEL="Pro/deepseek-ai/DeepSeek-V3"
# 审阅模型（可选，留空则使用编排模型）
LLM_REVIEWER_MODEL=""
# 请求超时（毫秒，默认 15000）
LLM_TIMEOUT_MS=30000
# 提供商类型（默认 openai-compatible）
LLM_PROVIDER="openai-compatible"

# ---------- 数据存储 ----------
# JSON 文件存储目录（默认 .prototype-store）
# PROTOTYPE_DATA_DIR=".prototype-store"

# ---------- 测试 ----------
# E2E 测试模式：跳过 CSRF 和验证码校验
# E2E_TEST_MODE="true"

# ---------- 本地靶场 ----------
# WebGoat 端口（默认 18080）
# WEBGOAT_HOST_PORT=18080
