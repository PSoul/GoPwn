# === Required ===
PROTOTYPE_SESSION_SECRET=   # Session signing key (generate a random 32+ char string)

# === LLM Configuration ===
LLM_API_KEY=                # API key for LLM provider
LLM_BASE_URL=               # Base URL (e.g., https://api.openai.com/v1)
LLM_ORCHESTRATOR_MODEL=     # Model for planning (e.g., gpt-4o)
LLM_REVIEWER_MODEL=         # Model for review (optional, defaults to orchestrator model)
LLM_TIMEOUT_MS=15000        # LLM request timeout in ms

# === Database (future) ===
DATABASE_URL=postgresql://pentest:pentest@localhost:5432/pentest

# === Docker Labs ===
WEBGOAT_HOST_PORT=18080
